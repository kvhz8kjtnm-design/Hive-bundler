# Dev/deployer wallet - this wallet creates the token and does the dev buy
SIGNER_PRIVATE_KEY=your_base58_private_key_here

# Funder/fee-payer wallet - funds sub-wallets and pays transaction fees
FUNDER_PRIVATE_KEY=your_base58_private_key_here

# Solana RPC URL - use a private RPC for best results
RPC_URL=https://api.mainnet-beta.solana.com

# Jito block engine - pick the region closest to you:
# Europe:        amsterdam.mainnet.block-engine.jito.wtf
#                frankfurt.mainnet.block-engine.jito.wtf
# North America: ny.mainnet.block-engine.jito.wtf
#                slc.mainnet.block-engine.jito.wtf
# Asia:          tokyo.mainnet.block-engine.jito.wtf
BLOCK_ENGINE_URLS=["frankfurt.mainnet.block-engine.jito.wtf"]
